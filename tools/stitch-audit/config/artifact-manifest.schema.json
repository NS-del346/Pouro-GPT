{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pouro.invalid/stitch-audit/artifact-manifest.schema.json",
  "title": "Pourō normalized Stitch artifact manifest",
  "type": "object",
  "required": ["project", "setId", "generatedAt", "sourceAuthorityIds", "artifactStatus", "screens"],
  "properties": {
    "project": { "const": "NS-del346/Pouro-GPT" },
    "setId": { "enum": ["set-a", "set-b", "set-c"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceAuthorityIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "artifactStatus": { "type": "string", "minLength": 1 },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stateId", "fileName", "htmlFileName", "expectedWidth", "expectedHeight", "methodId", "variantId", "recipeTruthSummary", "sourceStatus", "verificationLevel", "knownGaps"],
        "properties": {
          "stateId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "fileName": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*__[1-9][0-9]*x[1-9][0-9]*\\.png$" },
          "htmlFileName": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*__[1-9][0-9]*x[1-9][0-9]*\\.html$" },
          "expectedWidth": { "type": "integer", "minimum": 1 },
          "expectedHeight": { "type": "integer", "minimum": 1 },
          "methodId": { "type": ["string", "null"] },
          "variantId": { "type": ["string", "null"] },
          "recipeTruthSummary": { "type": ["object", "string"] },
          "sourceStatus": { "type": "string", "minLength": 1 },
          "verificationLevel": { "type": "string", "minLength": 1 },
          "knownGaps": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
